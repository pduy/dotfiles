; vim:ft=dosini
;=====================================================
;
;   To learn more about how to configure Polybar
;   go to https://github.com/jaagr/polybar
;
;   The README contains alot of information
;
;=====================================================
[global/wm]
margin-top = 0
margin-bottom = 0
include-file = ~/.config/polybar/colors.ini
include-file = ~/.config/polybar/bars.ini
include-file = ~/.config/polybar/glyphs.ini
include-file = ~/.config/polybar/modules.ini

[bar/default]
monitor = ${env:MONITOR:}
monitor-fallback = eDP-1
enable-ipc = true
width = 100%
height = 22
;offset-x = 1%
;offset-y = 1%
;radius = 6.0
fixed-center = true

background = ${color.background}
foreground = ${color.foreground}

line-size = 2
line-color = ${color.foreground}

underline-size = 2
underline-color = ${color.foreground}

border-size = 0
border-color = ${color.background}

padding-left = 0
padding-right = 0

module-margin-left = 0
module-margin-right = 0

;font-0 = Roboto:pixelsize=13;1
;font-1 = Inconsolata:size=9;1
;font-2 = Noto Color Emoji:scale=11:style=Regular;2
;font-3 = Symbola:pixelsize=10;1

font-0 = "Iosevka Nerd Font:pixelsize=13;3"
font-1 = "Caskaydia Cove Nerd Font:style=Regular:pixelsize=23;3"
font-2 = "Iosevka Nerd Font:style=Medium:size=23;5"
font-3 = "FontAwesome:style=Regular:pixelsize=13;3"
font-4 = "Font Awesome 5 Free,Font Awesome 5 Free Solid:style=Solid"
font-5 = "Font Awesome 5 Free,Font Awesome 5 Free Regular:style=Regular"
font-6 = "Font Awesome 5 Brands,Font Awesome 5 Brands Regular:style=Regular"
font-7 = "Siji:style=Regular:size=14;3"
font-8 = "Noto Color Emoji:scale=11:style=Regular;2"
font-9 = "Code2000:style=Regular"
font-10 = "Unifont:style=Regular"

; Other modules: xkeyboard filesystem xbacklight backlight-acpi cpu memory temperature powermenu weather
modules-left = right02 title left2
modules-center = right02 bspwm left2
modules-right = right7 weather right6 filesystem right5 pulseaudio right4 memory cpu right3 temperature right2 date right1 battery tray sysmenu

wm-restack = bspwm

;override-redirect = true

scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev

[module/mutt-wizard]

type = custom/script
exec = mailbox
interval = 5
format-prefix = " "
format-underline = ${color.red}

click-left = $TERMINAL -e neomutt


[module/weather]

type = custom/script
exec = curl -s wttr.in/Berlin\?format="%l+%c+%t"
interval = 500
;format-underline = ${color.red}
format-background = ${color.shade7}
;
[module/active-germany]

type = custom/script
exec = curl -s https://www.worldometers.info/coronavirus/country/germany/ | grep number-table-main | head -2 | tail -1 | awk -F '>' '{print$2}' | awk -F '<' '{print$1}'
format-prefix = "Germany Active: "
interval = 10800
format-underline = ${color.darkgreen}
format-background = ${color.cellbackground}

[module/xwindow]
type = internal/xwindow
;label = %title:0:45:...%
label = %title%
label-maxlen = 75
format-foreground = ${color.background}
format-background = ${color.titlebackground}
format-padding = 15

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = " "
format-prefix-foreground = ${color.gray}
format-prefix-underline = ${color.darkmagenta}

label-layout = %layout%
label-layout-underline = ${color.darkmagenta}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${color.darkmagenta}
label-indicator-underline = ${color.darkmagenta}

;[module/filesystem]
;type = internal/fs
;interval = 30 
;
;mount-0 = /
;mount-1 = /media/duy/SSD2
;
;label-mounted-underline = ${color.cyan}
;label-mounted = /: %free%
;label-unmounted = %mountpoint% not mounted
;label-unmounted-foreground = ${color.gray}
;format-background = ${color.cellbackground}

[module/bspwm]
type = internal/bspwm

;ws-icon-0 = 1;♚
;ws-icon-1 = 2;♛
;ws-icon-2 = 3;♜
;ws-icon-3 = 4;♝
;ws-icon-4 = 5;♞
;ws-icon-default = ♟

ws-icon-0 = 1;
ws-icon-1 = 2;
ws-icon-2 = 3;
ws-icon-3 = 4;
ws-icon-4 = 5;
ws-icon-default = 

;label-dimmed-foreground = ${}
;label-dimmed-underline = ${color.lightgray}
;label-dimmed-focused-background = ${color.gray}

label-focused =  %name%
label-focused-foreground = ${color.foreground-alt}
label-focused-background = ${color.shade2}
label-focused-padding = 1

label-occupied =  %name%
label-occupied-foreground = ${color.foreground-alt}
label-occupied-padding = 1

label-urgent =  %name%
label-urgent-foreground = ${color.shade2}
label-urgent-padding = 1

label-empty = %icon% %name%
label-empty-foreground = ${color.foreground-alt}
label-empty-padding = 1

pin-workspaces = true

[module/mpd]
type = internal/mpd
format-online = <label-song>  <label-time>

click-left = $TERMINAL -e ncmpcpp
click-right = mpc toggle

label-song =  %artist% - %title%
label-song-maxlen = 70
label-song-ellipsis = true

format-paused-foreground = ${color.gray}

[module/xbacklight]
type = internal/xbacklight

format = <label> <bar>
label = ﯧ

bar-width = 10
bar-indicator = |
bar-indicator-foreground = #ff
bar-indicator-font = 2
bar-fill = ─
bar-fill-font = 2
bar-fill-foreground = #9f78e1
bar-empty = ─
bar-empty-font = 2
bar-empty-foreground = ${color.gray}

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/cpu]
type = internal/cpu
interval = 1
;format-prefix = "🌡CPU "
format-prefix = "﬙ "
;format-prefix-foreground = ${color.gray}
;format-underline = ${color.red}
;format-background = ${color.cellbackground}
format-background = ${color.shade4}
format-padding = 1
label = %percentage%%

[module/memory]
type = internal/memory
interval = 1
format-prefix = "🧠"
format-prefix-foreground = ${color.foreground}
;format-underline = ${color.darkcyan}
format-background = ${color.shade4}
format-padding = 1
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp2s0
interval = 3.0
format-background = ${color.cellbackground}

format-connected = 直 <label-connected>
format-connected-underline = ${color.darkmagenta}
label-connected = %essid%

;format-disconnected =
format-disconnected = <label-disconnected>
format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
label-disconnected = 睊no wifi
label-disconnected-foreground = ${color.gray}

; <ramp-signal>
ramp-signal-0 = 
ramp-signal-1 = 
ramp-signal-2 = 
ramp-signal-3 = 
ramp-signal-4 = 
ramp-signal-foreground = ${color.gray}

[module/eth]
type = internal/network
interface = enp0s25
interval = 3.0

format-connected-underline = ${color.darkgreen}
;format-connected-underline = ${color.green}
format-connected-prefix = " "
format-connected-prefix-foreground = ${color.gray}
label-connected = %local_ip%

;format-disconnected =
format-disconnected = <label-disconnected>
format-disconnected-underline = ${self.format-connected-underline}
label-disconnected =  %ifname%
label-disconnected-foreground = ${color.gray}

;[module/date]
;type = internal/date
;interval = 60
;
;date = "%Y %b %d (%a)"
;time = "%I:%M%p"
;
;# If you're not living in a country where AM and PM is used you can add -alt to the time above this line and comment it using ;, then you can remove the -alt to the time under this line and uncomment it.
;;time-alt = " at %H:%M"
;;time-alt = %H:%M:%S
;;time-alt = %H:%M:%S
;
;format-prefix = " "
;format-prefix-foreground = ${color.gray}
;format-underline = ${color.blue}
;format-background = ${color.cellbackground}

;label = %date% %time%

;[module/volume]
;type = internal/alsa
;
;format-volume = <label-volume> <bar-volume>
;label-volume = 
;label-volume-foreground = ${root.foreground}
;
;format-muted-prefix = " "
;format-muted-foreground = ${color.gray}
;label-muted = muted
;
;bar-volume-width = 10
;bar-volume-foreground-0 = ${color.blue}
;bar-volume-foreground-1 = ${color.blue}
;bar-volume-foreground-2 = ${color.green}
;bar-volume-foreground-3 = ${color.green}
;bar-volume-foreground-4 = ${color.green}
;bar-volume-foreground-5 = ${color.yellow}
;bar-volume-foreground-6 = ${color.red}
;bar-volume-gradient = false
;bar-volume-indicator = |
;bar-volume-indicator-font = 2
;bar-volume-fill = =
;bar-volume-fill-font = 2
;bar-volume-empty = =
;bar-volume-empty-font = 2
;bar-volume-empty-foreground = ${color.gray}

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 75

;format-prefix = "🌡"
format = <ramp> <label> 
;format-underline = ${color.red}
format-warn = <ramp> <label-warn> 
;format-warn-underline = ${self.format-underline}
format-background = ${color.shade3}

label = %temperature-c% 
label-warn = %temperature-c%
label-warn-foreground = ${color.foreground-alt}
label-warn-background = ${color.shade3}

ramp-0 = 
ramp-1 = 
ramp-2 = 
ramp-3 = 
ramp-4 = 
ramp-foreground = ${color.foreground-alt}

[module/sysmenu]
type = custom/text
format = 
;format = sys

; "content" has the same properties as "format-NAME"
format-background = ${color.shade1}
format-foreground = ${color.foreground}
;;content-padding = 4

; "click-(left|middle|right)" will be executed using "/usr/bin/env sh -c $COMMAND"
click-left = ~/.config/polybar/scripts/powermenu.sh &
click-right = pavucontrol &


[module/tray]
type = internal/tray

; Optional: Adjust icon size and spacing
tray-position = right
tray-padding = 0
tray-detached = false
tray-size = 14px
tray-spacing = 4px
format-background = ${color.shade1}
format-foreground = ${color.foreground}

; "scroll-(up|down)" will be executed using "/usr/bin/env sh -c $COMMAND"
;;scroll-up = ~/.config/polybar/scripts/powermenu
;;scroll-down = ~/.config/polybar/scripts/powermenu

;; _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
format-background = ${color.background}
;format-padding = 1

